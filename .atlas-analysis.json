  "keyFeatures": [
    "Real-time GPS tracking with 200+ supported device protocols",
    "REST API for full programmatic access",
    "Geofencing with enter/exit event detection",
    "Alarms and multi-channel notifications (email, SMS, Telegram, Firebase, Pushover, WhatsApp)",
    "Detailed reports: routes, trips, stops, summary, and events",
    "Remote device commands (lock, unlock, engine cut-off, etc.)",
    "Driver behavior monitoring (speeding, harsh braking/acceleration)",
    "Multi-user account management with role-based permissions",
    "Docker-based deployment with MySQL, PostgreSQL, and H2 support",
    "OpenID Connect and LDAP authentication",
    "Computed attributes for custom telemetry processing",
    "Live video streaming support"
  ],
  "publicApiSurface": [
    "GET /api/session — Authenticate and get current user",
    "POST /api/session — Login with credentials",
    "GET /api/devices — List devices",
    "POST /api/devices — Create device",
    "GET /api/positions — Get latest or historical positions",
    "GET /api/geofences — List geofences",
    "POST /api/geofences — Create geofence",
    "GET /api/notifications — List notifications",
    "GET /api/reports/route — Route report",
    "GET /api/reports/trips — Trip report",
    "GET /api/reports/stops — Stops report",
    "GET /api/reports/summary — Summary report",
    "GET /api/reports/events — Events report",
    "POST /api/commands/send — Send command to device",
    "GET /api/events/{id} — Get event by ID",
    "GET /api/users — List users (admin only)",
    "POST /api/permissions — Link objects/permissions",
    "GET /api/groups — List groups",
    "GET /api/drivers — List drivers",
    "GET /api/attributes/computed — List computed attributes",
    "GET /api/maintenance — List maintenance records",
    "GET /api/calendars — List calendars",
    "GET /api/statistics — Server statistics (admin only)",
    "GET /api/server — Server configuration",
    "GET /api/audit — Audit log (admin only)"
  ]
}
